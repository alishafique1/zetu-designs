# ============================================================
# Social Dots Design Studio — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ---- Database (PostgreSQL via docker-compose) ----
POSTGRES_PASSWORD=your-secure-postgres-password

# ---- Supabase (PostgreSQL connection) ----
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://studio_user:your-password@db:5432/social_dots_studio
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ---- AI (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Clerk Auth ----
# Get these from clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ---- Internal ----
# Random 32+ char string for API auth between frontend and backend
INTERNAL_API_KEY=change-me-to-a-random-secret

# ---- App URL (for Stripe webhooks / redirects) ----
NEXT_PUBLIC_APP_URL=https://your-domain.com
